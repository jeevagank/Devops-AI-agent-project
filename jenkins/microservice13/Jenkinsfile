pipeline {
    agent {
        kubernetes {
            label 'default-agent'
            defaultContainer 'tools'
        }
    }

    environment {
        APP_NAME      = "microservice13"
        AWS_REGION    = "ap-southeast-2"
        ECR_REGISTRY  = credentials('ecr-registry-url')
        IMAGE_TAG     = "${env.GIT_COMMIT[0..7]}"
        IMAGE_NAME    = "${ECR_REGISTRY}/${APP_NAME}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Resolve Environment') {
            steps {
                script {
                    switch (env.BRANCH_NAME) {
                        case 'main':
                            env.DEPLOY_ENV    = 'prod'
                            env.AWS_ROLE_ARN  = credentials('aws-role-arn-prod')
                            env.EKS_CLUSTER   = 'prod-jeevagan-eks'
                            break
                        case ~/release\/.*/:
                            env.DEPLOY_ENV    = 'staging'
                            env.AWS_ROLE_ARN  = credentials('aws-role-arn-staging')
                            env.EKS_CLUSTER   = 'staging-jeevagan-eks'
                            break
                        default:
                            env.DEPLOY_ENV    = 'dev'
                            env.AWS_ROLE_ARN  = credentials('aws-role-arn-dev')
                            env.EKS_CLUSTER   = 'dev-jeevagan-eks'
                    }
                    env.K8S_NAMESPACE = "${env.DEPLOY_ENV}-${APP_NAME}"
                    echo "Deploying ${APP_NAME}:${IMAGE_TAG} → ${env.DEPLOY_ENV} (${env.EKS_CLUSTER})"
                }
            }
        }

        stage('Build & Push') {
            // Kaniko builds the image and pushes to ECR in one step — no Docker daemon,
            // no privileged container. IRSA provides ECR credentials automatically.
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \\
                            --context=dir://docker/${APP_NAME} \\
                            --dockerfile=docker/${APP_NAME}/Dockerfile \\
                            --destination=${IMAGE_NAME}:${IMAGE_TAG} \\
                            --build-arg BUILD_DATE=\$(date -u +%Y-%m-%dT%H:%M:%SZ) \\
                            --build-arg GIT_COMMIT=${IMAGE_TAG} \\
                            --build-arg DEPLOY_ENV=${env.DEPLOY_ENV} \\
                            --cache=true \\
                            --cache-repo=${ECR_REGISTRY}/kaniko-cache \\
                            --compressed-caching=false \\
                            --snapshot-mode=redo
                    """
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                container('tools') {
                    sh """
                        trivy image \\
                            --exit-code 1 \\
                            --severity HIGH,CRITICAL \\
                            --no-progress \\
                            --format table \\
                            ${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
            post {
                always {
                    container('tools') {
                        sh """
                            trivy image \\
                                --exit-code 0 \\
                                --severity HIGH,CRITICAL \\
                                --format json \\
                                --output trivy-report-${APP_NAME}.json \\
                                ${IMAGE_NAME}:${IMAGE_TAG}
                        """
                    }
                    archiveArtifacts allowEmptyArchive: true, artifacts: "trivy-report-${APP_NAME}.json"
                }
            }
        }

        stage('Test') {
            steps {
                container('tools') {
                    // Run tests in an ephemeral pod on EKS — no local Docker needed.
                    sh """
                        kubectl run test-${APP_NAME}-${IMAGE_TAG} \\
                            --image=${IMAGE_NAME}:${IMAGE_TAG} \\
                            --restart=Never \\
                            --rm \\
                            --attach \\
                            --namespace=jenkins \\
                            -- python -m pytest tests/ -v --junitxml=test-results.xml
                    """
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results.xml'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv(credentialsId: 'sonarqube-token', installationName: 'SonarQube') {
                    sh """
                        sonar-scanner \\
                            -Dsonar.projectKey=${APP_NAME} \\
                            -Dsonar.sources=. \\
                            -Dsonar.projectVersion=${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // Push to ECR is handled by Kaniko in the Build & Push stage above.
        // This stage is kept as a checkpoint to confirm the image exists in ECR.

        stage('Sign Image') {
            steps {
                withCredentials([
                    file(credentialsId: 'cosign-private-key', variable: 'COSIGN_KEY'),
                    [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-ecr-credentials']
                ]) {
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} \\
                            | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        cosign sign --key ${COSIGN_KEY} --yes ${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Update Image Tag in Git') {
            // GitOps approach: Jenkins writes the new image tag back to values.yaml in Git.
            // ArgoCD detects the Git change and deploys — no conflict between Jenkins and ArgoCD.
            when {
                anyOf {
                    branch 'main'
                    branch 'dev'
                    expression { env.BRANCH_NAME ==~ /release\/.*/ }
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-credentials',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh """
                        git config user.email "jenkins@jeevagan.internal"
                        git config user.name "Jenkins"

                        # Write the new image tag into the env-specific values file
                        sed -i 's|^  tag:.*|  tag: "${IMAGE_TAG}"|' helm/${APP_NAME}/values-${env.DEPLOY_ENV}.yaml
                        sed -i 's|^  registry:.*|  registry: "${ECR_REGISTRY}"|' helm/${APP_NAME}/values.yaml

                        git add helm/${APP_NAME}/values-${env.DEPLOY_ENV}.yaml helm/${APP_NAME}/values.yaml
                        git commit -m "ci: update ${APP_NAME} image tag to ${IMAGE_TAG} for ${env.DEPLOY_ENV} [skip ci]"
                        git push https://\${GIT_USER}:\${GIT_TOKEN}@github.com/jeevagank/Devops-AI-agent-project.git HEAD:${env.BRANCH_NAME}
                    """
                }
            }
            // ArgoCD detects this Git commit and automatically syncs the cluster.
            // No direct helm upgrade from Jenkins — Git is the single source of truth.
        }
    }

    post {
        always {
            // No local image cleanup needed — Kaniko pushes directly to ECR.
            cleanWs()
        }
        failure {
            echo "Pipeline failed for ${APP_NAME}:${IMAGE_TAG} on ${env.DEPLOY_ENV}"
        }
    }
}
