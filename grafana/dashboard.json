{
  "title": "Jeevagan EKS Platform Dashboard",
  "uid": "jeevagan-eks-platform",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_cpu_seconds_total, instance)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle', instance=~'$node'}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Node Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{instance=~'$node'} / node_memory_MemTotal_bytes{instance=~'$node'})) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Node Disk Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint='/', instance=~'$node'} / node_filesystem_size_bytes{mountpoint='/', instance=~'$node'})) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 4,
      "title": "Node Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~'$node', device!='lo'}[5m])",
          "legendFormat": "rx {{ instance }} {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~'$node', device!='lo'}[5m])",
          "legendFormat": "tx {{ instance }} {{ device }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 5,
      "title": "Microservice Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=~'$namespace'}[5m])) by (service, namespace)",
          "legendFormat": "{{ namespace }}/{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 6,
      "title": "Microservice Error Rate %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=~'$namespace', status=~'5..'}[5m])) by (service, namespace) / sum(rate(http_requests_total{namespace=~'$namespace'}[5m])) by (service, namespace) * 100",
          "legendFormat": "{{ namespace }}/{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Microservice p50 / p95 / p99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=~'$namespace'}[5m])) by (le, service, namespace))",
          "legendFormat": "p50 {{ namespace }}/{{ service }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=~'$namespace'}[5m])) by (le, service, namespace))",
          "legendFormat": "p95 {{ namespace }}/{{ service }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=~'$namespace'}[5m])) by (le, service, namespace))",
          "legendFormat": "p99 {{ namespace }}/{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "Pod Restart Count",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~'$namespace'}[1h])) by (namespace, pod)",
          "legendFormat": "{{ namespace }}/{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Pod Ready Status",
      "type": "stat",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kube_pod_status_ready{condition='true', namespace=~'$namespace'}) by (namespace)",
          "legendFormat": "Ready — {{ namespace }}"
        },
        {
          "expr": "sum(kube_pod_status_ready{condition='false', namespace=~'$namespace'}) by (namespace)",
          "legendFormat": "Not Ready — {{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 10,
      "title": "HPA Current vs Max Replicas",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~'$namespace'}",
          "legendFormat": "current — {{ namespace }}/{{ horizontalpodautoscaler }}"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=~'$namespace'}",
          "legendFormat": "max — {{ namespace }}/{{ horizontalpodautoscaler }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
