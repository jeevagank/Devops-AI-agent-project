{
  "title": "EKS Node Metrics",
  "uid": "jeevagan-eks-staging",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "constant",
        "query": "staging",
        "hide": 1
      },
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_cpu_seconds_total{job='node-exporter'}, instance)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle', instance=~'$node'}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Node Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{instance=~'$node'} / node_memory_MemTotal_bytes{instance=~'$node'})) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Node Disk Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint='/', instance=~'$node'} / node_filesystem_size_bytes{mountpoint='/', instance=~'$node'})) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "title": "Node Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~'$node', device!='lo'}[5m])",
          "legendFormat": "rx {{ instance }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~'$node', device!='lo'}[5m])",
          "legendFormat": "tx {{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 5,
      "title": "Node Count",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(kube_node_info)", "legendFormat": "Total Nodes" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Node Ready Status",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{condition='Ready', status='true'})",
          "legendFormat": "Ready"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
